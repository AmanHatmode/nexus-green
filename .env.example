# ============================================================
# Nexus Green API — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# Google Cloud / Gemini AI
# ------------------------------------------------------------

# Path to your Google Cloud service account credentials JSON file.
# Used for accessing Google Cloud APIs (e.g. Vision AI, Vertex AI).
# Download from: https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_APPLICATION_CREDENTIALS="./google-credentials.json"

# Your Gemini / Google Generative AI API key.
# Get it from: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY="YOUR_GEMINI_API_KEY"

# ------------------------------------------------------------
# Supabase
# ------------------------------------------------------------

# Your Supabase project URL.
# Found in: Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL="YOUR_SUPABASE_URL"

# Your Supabase anonymous (public) API key.
# Found in: Supabase Dashboard → Project Settings → API → anon / public key
# This key is safe to expose on the client side (it enforces Row Level Security).
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
