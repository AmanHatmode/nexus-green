function calcRiskScore(temp: number): number {
  if (temp > 42) return Math.min(10, 7 + (temp - 42) * 0.3);
  if (temp > 38) return 4 + (temp - 38) * 0.75;
  return Math.max(1, temp - 30);
}

const DAY_LABELS = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

